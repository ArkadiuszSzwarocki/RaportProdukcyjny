# RaportProdukcyjny Environment Configuration
# Copy this file to .env and fill in actual values for your environment

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=your-secret-key-here-min-32-chars

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=raportprodukcyjny
DB_PASSWORD=your-db-password
DB_NAME=raportprodukcyjny
DB_CHARSET=utf8mb4

# Admin Account (created at startup if INITIAL_ADMIN_PASSWORD is set)
INITIAL_ADMIN_PASSWORD=your-initial-admin-password

# Server Configuration
PORT=8082
HOST=0.0.0.0
WORKERS=6

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Optional: Report Generation
# (Leave empty if generator_raportow module is not available)
ENABLE_REPORT_GENERATION=true

# Print bridge configuration
# PRINTER_BRIDGE_URL is used by backend app service.
# For Docker/NAS this can point to a shared print gateway in LAN,
# e.g. https://192.168.1.50:3001 or http://192.168.1.50:3001
PRINTER_BRIDGE_URL=https://127.0.0.1:3001

# Optional: client-side fallback bridge for scanners/phones/browsers.
# If set, frontend fallback tries this endpoint first and then localhost.
# Example value: https://192.168.1.50:3001 (or http://... if app is served over HTTP)
PRINTER_CLIENT_BRIDGE_URL=

# Optional: Email sending (for shift close reports)
# SMTP_SERVER=mail.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-email-password

# Timezone
TZ=Europe/Warsaw

# Watchtower – automatyczna aktualizacja kontenerów z ghcr.io
# Wygeneruj token na: https://github.com/settings/tokens (uprawnienie: read:packages)
GHCR_USER=arkadiuszszwarocki
GHCR_TOKEN=your-github-pat-with-read-packages
